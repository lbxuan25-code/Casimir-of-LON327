__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/
/results/

# Root outputs: keep only lightweight reproducibility metadata before a production
# reference exists. Raw grids, figures, caches and full tables remain local.
outputs/**/logs/**
outputs/**/*.log
outputs/**/*.jsonl
outputs/**/*.tmp
outputs/**/*.active
outputs/**/raw/**
outputs/**/intermediate/**
outputs/**/cache/**
outputs/**/*.npz
outputs/**/*.npy
outputs/**/*.h5
outputs/**/*.hdf5
outputs/**/*.parquet
outputs/**/*.feather
outputs/**/*.pkl
outputs/**/*.pickle
outputs/**/*.npy.gz
outputs/**/*.npz.gz
outputs/**/*.csv.gz
outputs/**/*.json
outputs/**/*.csv
outputs/**/*.txt
outputs/**/*.png
outputs/**/*.pdf
outputs/**/*.svg
!outputs/**/summary*.json
!outputs/**/summary*.csv
!outputs/**/summary*.txt
!outputs/**/summary*.md
!outputs/**/status*.json
!outputs/**/run_config.json
!outputs/**/self_check.json
!outputs/**/README.md
!outputs/**/command.sh
!outputs/**/.gitkeep

# Validation runtime artifacts are reproducible local data. No generated validation
# output, including summaries or status snapshots, belongs in version control.
validation/cache/**
validation/logs/**
validation/outputs/**

# Hand-written validation documentation and compact immutable reference fixtures live
# outside validation/outputs and remain tracked normally.
