__pycache__/
*.py[cod]
.pytest_cache/

# Root outputs archive policy:
# keep human-readable summaries, figures, and lightweight summary metrics;
# ignore raw runtime artifacts, logs, caches, and complete large data dumps.
outputs/**/logs/**
outputs/**/*.log
outputs/**/*.jsonl
outputs/**/*.tmp
outputs/**/*.active
outputs/**/raw/**
outputs/**/intermediate/**
outputs/**/cache/**
outputs/**/*.npz
outputs/**/*.npy
outputs/**/*.h5
outputs/**/*.hdf5
outputs/**/*.parquet
outputs/**/*.feather
outputs/**/*.pkl
outputs/**/*.pickle
outputs/**/*.npy.gz
outputs/**/*.npz.gz
outputs/**/*.csv.gz

outputs/**/*.json
!outputs/**/summary*.json
!outputs/**/status*.json
!outputs/**/run_config.json
!outputs/**/self_check.json
!outputs/**/README.md
!outputs/**/command.sh
!outputs/**/.gitkeep

outputs/**/data/**
!outputs/**/data/
!outputs/**/data/**/
!outputs/**/data/.gitkeep
!outputs/**/data/*summary*.csv
!outputs/**/data/*summary*.json
!outputs/**/data/*aggregate*.csv
!outputs/**/data/*aggregate*.json
!outputs/**/data/*metrics*.csv
!outputs/**/data/*metrics*.json
!outputs/**/data/*metadata*.csv
!outputs/**/data/*metadata*.json
!outputs/**/data/*convergence*.csv
!outputs/**/data/*convergence*.json

!outputs/**/figures/
!outputs/**/figures/**/
!outputs/**/figures/**/*.png
!outputs/**/figures/**/*.pdf
!outputs/**/figures/**/*.svg

# Validation generated artifacts
validation/cache/**/*.npz
validation/cache/**/*.npy
validation/cache/**/*.csv
validation/cache/**/*.jsonl

validation/outputs/**/data/*.npz
validation/outputs/**/data/*.npy
validation/outputs/**/data/*.csv
validation/outputs/**/data/*expanded*.csv
validation/outputs/**/data/*raw*.csv
validation/outputs/**/raw/**
validation/outputs/**/intermediate/**
validation/outputs/**/figures/*.png
validation/outputs/**/figures/*.pdf
validation/logs/*.log
validation/logs/**/*.log

# Keep validation documentation and lightweight summaries
!validation/README.md
!validation/reports/**
!validation/outputs/**/README.md
!validation/outputs/**/*summary*.md
!validation/outputs/**/*summary*.json
!validation/outputs/**/*summary*.csv
!validation/outputs/**/*status*.json
!validation/outputs/**/command.sh
!validation/outputs/**/*command*.sh

# Historical large reproducible unit-audit data
validation/outputs/**/data/*.npz
validation/outputs/**/data/*expanded*.csv
validation/outputs/units/casimir_q_grid_model_q_audit/data/casimir_q_grid_model_q_audit.csv

