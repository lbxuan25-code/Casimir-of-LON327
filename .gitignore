__pycache__/
*.py[cod]
.pytest_cache/
/results/

# Root outputs: keep lightweight summaries and reproducibility metadata only.
outputs/**/logs/**
outputs/**/*.log
outputs/**/*.jsonl
outputs/**/*.tmp
outputs/**/*.active
outputs/**/raw/**
outputs/**/intermediate/**
outputs/**/cache/**
outputs/**/*.npz
outputs/**/*.npy
outputs/**/*.h5
outputs/**/*.hdf5
outputs/**/*.parquet
outputs/**/*.feather
outputs/**/*.pkl
outputs/**/*.pickle
outputs/**/*.npy.gz
outputs/**/*.npz.gz
outputs/**/*.csv.gz
outputs/**/*.json
!outputs/**/summary*.json
!outputs/**/status*.json
!outputs/**/run_config.json
!outputs/**/self_check.json
!outputs/**/README.md
!outputs/**/command.sh
!outputs/**/.gitkeep
!outputs/**/data/
!outputs/**/data/**/
!outputs/**/figures/
!outputs/**/figures/**/
!outputs/**/figures/**/*.png
!outputs/**/figures/**/*.pdf
!outputs/**/figures/**/*.svg

# Validation artifacts are reproducible local data unless explicitly summarized.
validation/cache/**
validation/logs/**
validation/outputs/**/raw/**
validation/outputs/**/intermediate/**
validation/outputs/**/*.log
validation/outputs/**/*.json
validation/outputs/**/*.csv
validation/outputs/**/*.txt
validation/outputs/**/*.tmp
validation/outputs/**/*.active
validation/outputs/**/*.npz
validation/outputs/**/*.npy
validation/outputs/**/*.h5
validation/outputs/**/*.hdf5
validation/outputs/**/*.parquet
validation/outputs/**/*.feather
validation/outputs/**/*.pkl
validation/outputs/**/*.pickle
validation/outputs/**/*.png
validation/outputs/**/*.pdf
validation/outputs/**/*.svg

# Keep validation documentation and compact summaries.
!validation/README.md
!validation/reports/**
!validation/outputs/**/README.md
!validation/outputs/**/command.sh
!validation/outputs/**/.gitkeep
!validation/outputs/**/*summary*.md
!validation/outputs/**/*summary*.json
!validation/outputs/**/*summary*.csv
!validation/outputs/**/*summary*.txt
!validation/outputs/**/*status*.json
