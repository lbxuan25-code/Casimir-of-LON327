__pycache__/
*.py[cod]
.pytest_cache/
/results/

# Root outputs: keep lightweight summaries and reproducibility metadata only.
outputs/**/logs/**
outputs/**/*.log
outputs/**/*.jsonl
outputs/**/*.tmp
outputs/**/*.active
outputs/**/raw/**
outputs/**/intermediate/**
outputs/**/cache/**
outputs/**/*.npz
outputs/**/*.npy
outputs/**/*.h5
outputs/**/*.hdf5
outputs/**/*.parquet
outputs/**/*.feather
outputs/**/*.pkl
outputs/**/*.pickle
outputs/**/*.npy.gz
outputs/**/*.npz.gz
outputs/**/*.csv.gz
outputs/**/*.json
!outputs/**/summary*.json
!outputs/**/status*.json
!outputs/**/run_config.json
!outputs/**/self_check.json
!outputs/**/README.md
!outputs/**/command.sh
!outputs/**/.gitkeep
!outputs/**/data/
!outputs/**/data/**/
!outputs/**/figures/
!outputs/**/figures/**/
!outputs/**/figures/**/*.png
!outputs/**/figures/**/*.pdf
!outputs/**/figures/**/*.svg

# Validation artifacts: raw scans, caches and logs are reproducible local data.
validation/cache/**
validation/outputs/**/raw/**
validation/outputs/**/intermediate/**
validation/outputs/**/data/*.npz
validation/outputs/**/data/*.npy
validation/outputs/**/data/*.csv
validation/outputs/**/figures/*.png
validation/outputs/**/figures/*.pdf
validation/logs/**

# Keep validation documentation and compact summaries.
!validation/README.md
!validation/reports/**
!validation/outputs/**/README.md
!validation/outputs/**/*summary*.md
!validation/outputs/**/*summary*.json
!validation/outputs/**/*summary*.csv
!validation/outputs/**/*status*.json
!validation/outputs/**/command.sh
